# Copy to .env and fill local secrets. .env is ignored by git.
JINA_API_KEY=
SERPER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://ie-crs.haoxiang.ai
OPENAI_MODEL=gpt-5.5

# Optional server override used by scripts/start.sh.
RESEARCHRADAR_HOST=0.0.0.0
RESEARCHRADAR_PORT=8766

# Keep local dashboard/API calls from being sent through HTTP_PROXY/HTTPS_PROXY.
NO_PROXY=localhost,127.0.0.1,::1,0.0.0.0,127.0.0.0/8
no_proxy=localhost,127.0.0.1,::1,0.0.0.0,127.0.0.0/8
